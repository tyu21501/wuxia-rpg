# ════════════════════════════════════════════════════════════════
# 玄冥江湖 · AI 引擎配置範本
# 複製此文件為 .env 並填入設定
# ════════════════════════════════════════════════════════════════

# ── 選項 A：Anthropic Claude API（推薦）────────────────────────
# 取得 API Key：https://console.anthropic.com/
# claude-haiku → 最快最省費，適合日常遊玩
# claude-sonnet-4-6 → 最佳敘事品質（預設）
ANTHROPIC_API_KEY=sk-ant-你的密鑰
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── 選項 B：Ollama 本地 LLM（免費，需要較強 GPU）──────────────
# 1. 安裝 Ollama：https://ollama.com/download
# 2. 拉取模型：ollama pull deepseek-r1:8b （約5GB，需8GB VRAM）
# 3. 啟動服務：ollama serve
# USE_OLLAMA=true
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=deepseek-r1:8b

# ── 選項 C：不設定（使用內建豐富敘事庫）───────────────────────
# 無需任何 API！narrative-engine.mjs 提供完整的武俠恐怖敘事體驗：
# • 10 個地點各有 4-8 種行動專屬敘事模板
# • 8 個 NPC 的個性化對話庫（含線索揭示）
# • 動態狀態更新（理智/聲望/線索/信任度）
# 只需讓 ANTHROPIC_API_KEY 保持空白即可。

# ── 儲存系統設定（Vercel 部署用）─────────────────────────────────
# 本地開發：自動使用 JSON 檔案 (data/world-state.json, data/saves/*, data/users/*)
# Vercel 部署：如果設定下列環境變數，自動使用 Upstash Redis KV
# 推薦：https://upstash.com → 免費方案每月 10,000 個指令
KV_REST_API_URL=https://your-kv-url.upstash.io
KV_REST_API_TOKEN=your-kv-token

# ── 伺服器設定 ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT 與安全設定（Vercel 部署專用）──────────────────────────
JWT_SECRET=your_very_long_random_secret_here_min_32_chars
SESSION_SECRET=another_random_secret_for_sessions_min_32_chars

# ── 資料庫設定（未來用）────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost/wuxia
# REDIS_URL=redis://localhost:6379

# ── 部署設定 ────────────────────────────────────────────────────
# 開發環境：http://localhost:3000
# 生產環境（Vercel）：https://your-project.vercel.app
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3000/api
